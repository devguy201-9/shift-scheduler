        }
      }
    },
    {
      "name": "Get Result - NOT FOUND",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{SCHEDULING_SERVICE_URL}}/api/v1/schedules/00000000-0000-0000-0000-000000000000/result",
          "host": [
            "{{SCHEDULING_SERVICE_URL}}"
          ],
          "path": [
            "api",
            "v1",
            "schedules",
            "00000000-0000-0000-0000-000000000000",
            "result"
          ]
        }
      }
    },
    {
      "name": "VALID ASSIGNMENT (1 STAFF, 1 WEEK)",
      "item": [
        {
          "name": "Create Schedule - 1 Staff",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"staff_group_id\": \"{{group_id_1_staff}}\",\n  \"period_begin_date\": \"2025-01-06\"\n}"
            },
            "url": {
              "raw": "{{SCHEDULING_SERVICE_URL}}/api/v1/schedules",
              "host": [
                "{{SCHEDULING_SERVICE_URL}}"
              ],
              "path": [
                "api",
                "v1",
                "schedules"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 202', () => pm.response.to.have.status(202));",
                  "pm.environment.set('schedule_id', pm.response.json().schedule_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Check Status - Should COMPLETE",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{SCHEDULING_SERVICE_URL}}/api/v1/schedules/{{schedule_id}}/status",
              "host": [
                "{{SCHEDULING_SERVICE_URL}}"
              ],
              "path": [
                "api",
                "v1",
                "schedules",
                "{{schedule_id}}",
                "status"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should be COMPLETED', () => {",
                  "  pm.expect(pm.response.text()).to.include('COMPLETED');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
